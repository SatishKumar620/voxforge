# Required — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# For real voice — get from murf.ai → Dashboard → API Keys
# Without this, narration runs in demo mode
MURF_API_KEY=your-murf-key-here

# Your deployed URL — IMPORTANT for audio file links
# Local: http://localhost:5000
# Render: https://your-app-name.onrender.com
BASE_URL=http://localhost:5000

PORT=5000

# Optional podcast metadata (shows in RSS feed)
PODCAST_TITLE=My VoxForge Podcast
PODCAST_AUTHOR=Your Name
PODCAST_EMAIL=you@example.com
PODCAST_LANG=en
